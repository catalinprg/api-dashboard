# Rename to `.env` and fill these in to enable GitHub OAuth login.
# If GITHUB_CLIENT_ID is not set, the dashboard runs with no auth (dev mode).

# ---- Required to enable auth ----
GITHUB_CLIENT_ID=Iv1.your-client-id
GITHUB_CLIENT_SECRET=your-client-secret
# Must EXACTLY match the "Authorization callback URL" on your GitHub OAuth App.
# For local dev through Vite's proxy, use:
GITHUB_REDIRECT_URI=http://localhost:5173/api/auth/github/callback
# In production behind HTTPS:
# GITHUB_REDIRECT_URI=https://dashboard.example.com/api/auth/github/callback

# ---- Allowlist (pick one) ----
# Preferred: comma-separated GitHub usernames. Stable identifier, can't be spoofed
# by changing email. Case-insensitive.
ALLOWED_LOGINS=your-github-username,other-person

# Fallback: comma-separated verified primary emails. Only used if ALLOWED_LOGINS is empty.
# ALLOWED_EMAILS=you@example.com

# If BOTH are empty, any GitHub user can sign in — don't do that in production.

# ---- Optional ----
# HMAC secret for signing session cookies. Defaults to backend/.secret.key contents.
# SESSION_SECRET=generate-with-openssl-rand-hex-32

# Cookie Secure flag: "true" (HTTPS only), "false", or "auto" (auto = on if redirect URI is https).
# COOKIE_SECURE=auto

# Where to send the user after a successful login. Default "/".
# POST_LOGIN_REDIRECT=/
