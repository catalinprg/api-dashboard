# Rename to `.env` and fill these in to enable Google OAuth login.
# If GOOGLE_CLIENT_ID is not set, the dashboard runs with no auth (dev mode).

# ---- Required to enable auth ----
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Must EXACTLY match one of the "Authorized redirect URIs" on your Google OAuth client.
# For local dev through Vite's proxy, use:
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback
# In production behind HTTPS:
# GOOGLE_REDIRECT_URI=https://dashboard.example.com/api/auth/google/callback

# Comma-separated allowlist. Leave empty to accept any verified Google email
# (NOT recommended — always set this).
ALLOWED_EMAILS=you@gmail.com

# ---- Optional ----
# HMAC secret for signing session cookies. Defaults to backend/.secret.key contents.
# SESSION_SECRET=generate-with-openssl-rand-hex-32

# Cookie Secure flag: "true" (HTTPS only), "false", or "auto" (auto = on if redirect URI is https).
# COOKIE_SECURE=auto

# Where to send the user after a successful login. Default "/".
# POST_LOGIN_REDIRECT=/
